{
    "workbench.startupEditor": "none",
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,
    "editor.fontFamily": "'JetBrainsMono NF', 'monospace', monospace",
    "editor.fontWeight": "750",
    "editor.fontSize": 14,
    "editor.lineHeight": 2,
    "workbench.colorTheme": "Gruvbox Material Dark",
    "gruvboxMaterial.darkContrast": "hard",
    "gruvboxMaterial.highContrast": true,
    "gruvboxMaterial.italicKeywords": true,
    "gruvboxMaterial.colorfulSyntax": true,
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.guides.bracketPairs": "active",
    "editor.tabSize": 2,
    "editor.fontLigatures": "calt, zero, frac, ss01, ss02, ss19, ss20, cv01, cv02, cv03, cv04, cv05, cv06, cv07, cv08, cv09, cv10, cv11, cv12, cv14, cv15, cv16, cv17, cv18, cv19, cv20, cv99",
    "security.workspace.trust.untrustedFiles": "newWindow",
    "security.workspace.trust.startupPrompt": "never",
    "security.workspace.trust.enabled": false,
    "workbench.sideBar.location": "right",
    "window.menuBarVisibility": "toggle",
    "editor.minimap.side": "right",
}
